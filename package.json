    "cors": "^2.8.5",
    "dompurify": "^3.3.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.1",
    "jsdom": "^27.4.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "redis": "^5.10.0",
